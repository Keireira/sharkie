{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "none",
			"semicolons": "always",
			"jsxQuoteStyle": "double",
			"bracketSameLine": false,
			"arrowParentheses": "always"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"useExhaustiveDependencies": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noArrayIndexKey": "warn"
			},
			"style": {
				"noNonNullAssertion": "error",
				"useImportType": "error",
				"useConst": "error",
				"useTemplate": "error"
			},
			"a11y": {
				"recommended": true,
				"noSvgWithoutTitle": "warn"
			},
			"security": {
				"noDangerouslySetInnerHtml": "warn"
			}
		}
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"overrides": [
		{
			"includes": ["**/*.json", "**/*.yaml", "**/*.yml"],
			"formatter": {
				"indentStyle": "space",
				"indentWidth": 2
			}
		}
	],
	"files": {
		"includes": ["**", "!**/node_modules", "!**/.next", "!**/out", "!**/public", "!**/dist", "!**/build"]
	}
}
